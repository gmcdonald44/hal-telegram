# --- Required ---

# Telegram bot token from @BotFather
# See SETUP.md §1
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID. Talk to @userinfobot to find it.
# Set this to lock the bot to single-owner mode.
# If unset, ANYONE who knows the bot handle can talk to your Claude Code.
TELEGRAM_OWNER_CHAT_ID=

# --- Optional ---

# Display name used in logs (default: "claude-tg-bot")
BOT_NAME=

# Claude model to spawn (default: claude-opus-4-7)
# Opus 4.7, Sonnet 4.6, Haiku 4.5 — pick whichever your subscription supports.
CLAUDE_MODEL=

# Path to a Claude Code settings.json (hooks, tool profiles).
# Defaults to .claude/settings.json inside this repo.
CLAUDE_SETTINGS_PATH=

# Temp dir for photo/document downloads (default: OS tmpdir + BOT_NAME)
TMP_DIR=

# "prod" or "sandbox" — controls which channel registry file is used.
# Lets you keep a test bot and a production bot on the same install.
BOT_MODE=prod
